# ============================================================================
# MedExplain AI — backend configuration template
# ----------------------------------------------------------------------------
# Copy this to `.env` and fill in your values:  cp .env.example .env
# NEVER commit `.env` (it holds secrets); THIS file is the committed template,
# so keep only placeholders here — put your real Gemini key in `.env`.
#
# Every setting has a safe local-dev default in app/core/config.py, so the app
# boots with zero config on a laptop. You only need to set what you override.
# All variables are prefixed MEDEXPLAIN_. Lines starting with `#` are optional
# overrides shown with their default value.
# ============================================================================

# --- Environment ------------------------------------------------------------
# dev | prod.  In `prod` the app REFUSES to boot unless MEDEXPLAIN_JWT_SECRET is
# changed from the default AND MEDEXPLAIN_CORS_ORIGINS is explicit (no "*").
MEDEXPLAIN_ENV=dev

# --- Security (REQUIRED in prod) --------------------------------------------
# Generate a strong secret:  python -c "import secrets; print(secrets.token_urlsafe(48))"
MEDEXPLAIN_JWT_SECRET=dev-only-change-me-please-use-a-long-random-secret
MEDEXPLAIN_JWT_ALGORITHM=HS256
MEDEXPLAIN_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS (REQUIRED in prod) ------------------------------------------------
# Comma-separated browser origins allowed to call the API. Credentials are on,
# so "*" is rejected in prod. In production set this to your frontend origin,
# e.g.  https://your-app.vercel.app
MEDEXPLAIN_CORS_ORIGINS=http://localhost:3000

# --- LLM providers ----------------------------------------------------------
# Default generation policy for NEW accounts:
#   cloud   = use Google Gemini (needs a key below)
#   offline = local Ollama, falling back to deterministic templates — NO egress
MEDEXPLAIN_DEFAULT_LLM_MODE=cloud

# Google Gemini key — enables `cloud` mode. Get one: https://aistudio.google.com/apikey
# WARNING: the FREE tier may use your inputs/outputs to improve Google's models and allows
# human review, and Google's terms forbid sensitive/personal data on the unpaid tier — do
# NOT use it with real patient data (use paid Vertex AI + a BAA for PHI). Leave empty to run
# fully local/offline (no network egress).
MEDEXPLAIN_GEMINI_API_KEY=
MEDEXPLAIN_GEMINI_MODEL=gemini-2.5-flash
# MEDEXPLAIN_GEMINI_TIMEOUT=20

# Local Ollama — used in `offline` mode, or as the cloud-mode fallback. ONE model only.
MEDEXPLAIN_OLLAMA_HOST=http://localhost:11434
# Gemma 3 4B = commercial-OK + strong grounding. Avoid qwen2.5 (non-commercial license).
MEDEXPLAIN_OLLAMA_MODEL=gemma3:4b
# MEDEXPLAIN_OLLAMA_TIMEOUT=180             # seconds (CPU inference is slow)

# Generation tuning (optional)
# MEDEXPLAIN_LLM_TEMPERATURE=0.2
# MEDEXPLAIN_LLM_MAX_OUTPUT_TOKENS=700

# --- Paths (relative paths resolve against the repo root, the parent of backend/) ---
# In Docker these live under /app; mount a persistent volume at /app/data.
MEDEXPLAIN_DB_PATH=data/medexplain.db
MEDEXPLAIN_UPLOAD_DIR=data/uploads
MEDEXPLAIN_VECTOR_STORE_DIR=vector_store
MEDEXPLAIN_KNOWLEDGE_BASE_DIR=knowledge_base

# --- Uploads & analysis limits ----------------------------------------------
MEDEXPLAIN_MAX_UPLOAD_MB=20
# MEDEXPLAIN_MAX_PAGES=50                   # reject documents with more pages than this
# MEDEXPLAIN_MAX_IMAGE_PIXELS=40000000      # cap decoded pixels (decompression-bomb guard)
# MEDEXPLAIN_ANALYSIS_ACQUIRE_TIMEOUT=600   # seconds to wait for the single analysis slot

# --- OCR (scanned / image pages) --------------------------------------------
# Warm-load the OCR engine at startup (recommended in prod when OCR is installed); off by
# default so dev/test boot stays fast (OCR then loads lazily on the first image page).
# Requires the 'ocr' extra:  uv sync --extra ocr   (or build the image with INSTALL_OCR=true)
MEDEXPLAIN_OCR_WARMUP=false

# --- Semantic RAG (optional; off by default) --------------------------------
# true = bge embeddings + a numpy cosine store to augment general free-text chat.
# Requires the 'rag' extra:  uv sync --extra rag
MEDEXPLAIN_USE_SEMANTIC_RAG=false
# MEDEXPLAIN_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
